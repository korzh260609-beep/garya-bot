{
  "version": 6,
  "coverage": "workflow_tree_auto_signals",
  "notes": [
    "Universal stage_check engine config",
    "No hard-coded workflow item ids",
    "No hard-coded semantic bindings to specific stages",
    "The checker extracts technical signals directly from WORKFLOW item text",
    "Signals include file paths, slash commands, snake_case, UPPER_CASE, camelCase, kebab-case, and backticked tokens",
    "If workflow numbering changes, checker still works because it does not bind checks to item ids",
    "If workflow wording changes, checker still works as long as technical signals remain present in the item text",
    "This file configures the engine only; it does not map individual stages or subtasks"
  ],
  "engine": {
    "max_checks_per_item": 12,
    "min_identifier_length": 3,
    "max_search_files_per_token": 300,
    "preferred_path_prefixes": [
      "src/",
      "core/",
      "migrations/",
      "scripts/",
      "pillars/",
      ""
    ],
    "searchable_extensions": [
      ".js",
      ".mjs",
      ".cjs",
      ".json",
      ".md",
      ".sql",
      ".txt",
      ".yaml",
      ".yml"
    ],
    "stop_tokens": [
      "stage",
      "stages",
      "workflow",
      "skeleton",
      "foundation",
      "mandatory",
      "future",
      "gate",
      "rules",
      "rule",
      "notes",
