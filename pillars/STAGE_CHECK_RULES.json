{
  "version": 2,
  "coverage": "generic_match_rules",
  "notes": [
    "Read-only static checks only",
    "Source of truth = WORKFLOW.md + repository files",
    "No AI",
    "No WORKFLOW_HINTS.json",
    "Rules are matched against workflow section text, not stage ids",
    "If no generic rule matches a stage, result must be NO_GENERIC_CHECKS"
  ],
  "rules": [
    {
      "id": "file_intake_skeleton_v1",
      "match": {
        "all_tokens": [
          "download file",
          "effectiveusertext"
        ],
        "any_tokens": [
          "ocr img",
          "pdf parse",
          "docx parse",
          "audio transcript",
          "data lifecycle skeleton"
        ],
        "none_tokens": [
          "vision analysis",
          "keyframe ocr",
          "emotion"
        ]
      },
      "checks": [
        {
          "type": "file_exists",
          "path": "src/documents/documentTextService.js",
          "label": "document text service"
        },
        {
          "type": "file_exists",
          "path": "src/bot/handlers/chat/chatDocumentEstimateFlow.js",
          "label": "document estimate flow"
        },
        {
          "type": "file_exists",
          "path": "src/bot/handlers/chat/chatEstimateReplies.js",
          "label": "estimate replies"
        },
        {
          "type": "file_exists",
          "path": "src/bot/handlers/chat/chatEstimateCorrectionFlow.js",
          "label": "estimate correction flow"
        },
        {
          "type": "file_exists",
          "path": "src/bot/handlers/chat/chatPendingClarificationFlow.js",
          "label": "pending clarification flow"
        }
      ]
    },
    {
      "id": "repo_indexing_readonly_foundation_v1",
      "match": {
        "all_tokens": [
          "read-only foundation"
        ],
        "any_tokens": [
          "github access",
          "reposource",
          "repoindexservice",
          "repoindexsnapshot",
          "memorypolicy",
          "reindex dry-run",
          "memorycandidates preview"
        ]
      },
      "checks": [
        {
          "type": "file_exists",
          "path": "src/repo/RepoSource.js",
          "label": "repo source"
        },
        {
          "type": "file_exists",
          "path": "src/bot/handlers/reindexRepo.js",
          "label": "reindex handler"
        },
        {
          "type": "file_exists",
          "path": "src/bot/handlers/repoStatus.js",
          "label": "repo status handler"
        },
        {
          "type": "file_exists",
          "path": "src/bot/handlers/repoTree.js",
          "label": "repo tree handler"
        },
        {
          "type": "file_exists",
          "path": "src/bot/handlers/repoFile.js",
          "label": "repo file handler"
        }
      ]
    }
  ]
}