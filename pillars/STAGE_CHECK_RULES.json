{
  "version": 7,
  "coverage": "workflow_tree_semantic_auto_signals",
  "notes": [
    "Universal stage_check engine config",
    "No hard-coded workflow item ids",
    "No hard-coded semantic bindings to specific stages",
    "The checker extracts semantic technical signals directly from WORKFLOW item text",
    "Signals include file paths, slash commands, snake_case, UPPER_CASE, camelCase, PascalCase, kebab-case, backticked tokens, and slash-list interfaces like write/read/context/recent",
    "Strong parent signals are inherited by child points and substages",
    "Strong descendant signals can help abstract parent containers",
    "If workflow numbering changes, checker still works because it does not bind checks to item ids",
    "If workflow text changes, checker should still work while technical semantic signals remain present"
  ],
  "engine": {
    "max_checks_per_item": 14,
    "min_identifier_length": 3,
    "max_search_files_per_token": 300,
    "max_inherited_signals": 6,
    "max_descendant_signals": 4,
    "preferred_path_prefixes": [
      "src/",
      "core/",
      "migrations/",
      "scripts/",
      "pillars/",
      ""
    ],
    "searchable_extensions": [
      ".js",
      ".mjs",
      ".cjs",
      ".json",
      ".md",
      ".sql",
      ".txt",
      ".yaml",
      ".yml"
    ],
    "stop_tokens": [
